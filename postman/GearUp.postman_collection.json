{
  "info": {
    "name": "GearUp API",
    "description": "Rent Sports & Outdoor Gear Instantly — full API collection for the GearUp backend assignment. Set {{baseUrl}} and run the Auth > Login requests to populate {{adminToken}}, {{providerToken}}, {{customerToken}} automatically (see each login request's Tests tab).",
