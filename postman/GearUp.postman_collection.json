      "name": "Auth",
      "item": [
        {
          "name": "Register (Customer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user. role can be CUSTOMER, PROVIDER, or ADMIN.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new.customer@example.com\",\n  \"password\": \"test1234\",\n  \"name\": \"New Customer\",\n  \"phone\": \"+8801700000001\",\n  \"address\": \"Dhaka\",\n  \"role\": \"CUSTOMER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": []
        },
        {
          "name": "Register (Provider)",
