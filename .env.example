# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
